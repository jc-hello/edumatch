# App
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5435
DB_NAME=edumatch
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_VERIFY_SECRET=
RESET_PASSWORD_SECRET=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Mail
MAIL_FROM=noreply@edumatch.vn
SENDGRID_API_KEY=

# Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9100
S3_BUCKET=edumatch
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
