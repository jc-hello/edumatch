{
  "name": "edumatch-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply edumatch --local",
    "db:migrate:remote": "wrangler d1 migrations apply edumatch",
    "db:create": "wrangler d1 create edumatch",
    "kv:create": "wrangler kv namespace create RATE_LIMIT",
    "r2:create": "wrangler r2 bucket create edumatch-storage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.93.0"
  }
}
